{
  "expo": {
    "name": "Garancije.rs",
    "slug": "garancijers",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "garancije",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7FAFC"
    },
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "package": "rs.garancije.app",
      "googleServicesFile": "./google-services.json",
      "navigationBar": {
        "backgroundColor": "#FFFFFF",
        "barStyle": "dark-content"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/foreground.png",
        "monochromeImage": "./assets/images/monochrome.png",
        "backgroundColor": "#F7FAFC"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Garancije.rs pristupa vašim fotografijama da biste izabrali sliku fiskalnog računa.",
          "cameraPermission": "Garancije.rs koristi kameru da biste slikali fiskalni račun.",
          "microphonePermission": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#062B5F",
          "defaultChannel": "reminders"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0cc9f77f-fe44-4ec6-9387-c81a8a466519"
      }
    },
    "owner": "urke86"
  }
}
