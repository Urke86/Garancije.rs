EXPO_NO_METRO_WORKSPACE_ROOT=1

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: override OAuth redirect (native). Web uses {origin}/auth/callback
# EXPO_PUBLIC_OAUTH_REDIRECT_URI=garancije://auth/callback

# Password reset deep link. Web uses {origin}/auth/reset-password automatically.
# Add the same URL(s) in Supabase → Authentication → URL Configuration → Redirect URLs.
# EXPO_PUBLIC_PASSWORD_RESET_REDIRECT=garancije://auth/reset-password

# Legal pages (Netlify or custom domain)
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://garancijers.netlify.app/privacy
EXPO_PUBLIC_TERMS_URL=https://garancijers.netlify.app/terms

# Supabase Edge Function secret (set via: supabase secrets set GOOGLE_VISION_API_KEY=...)
# Enables receipt OCR in ocr-receipt function — NOT used in the Expo app directly.
# GOOGLE_VISION_API_KEY=
