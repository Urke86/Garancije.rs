EXPO_NO_METRO_WORKSPACE_ROOT=1

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: override OAuth redirect (native). Web uses {origin}/auth/callback
# EXPO_PUBLIC_OAUTH_REDIRECT_URI=garancije://auth/callback

# Password reset deep link. Web uses {origin}/auth/reset-password automatically.
# Add the same URL(s) in Supabase → Authentication → URL Configuration → Redirect URLs.
# EXPO_PUBLIC_PASSWORD_RESET_REDIRECT=garancije://auth/reset-password

# Legal pages (Netlify or custom domain)
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://garancijers.netlify.app/privacy
EXPO_PUBLIC_TERMS_URL=https://garancijers.netlify.app/terms

# Supabase Edge Function secret (legacy cloud OCR — no longer used by the mobile app)
# GOOGLE_VISION_API_KEY=

# Push: closed tester update notifications (scripts/notify-app-update.mjs, notify-app-update function)
# CRON_SECRET=  # same secret as send-reminders (supabase secrets set CRON_SECRET=...)
# SUPABASE_SERVICE_ROLE_KEY=  # for npm run testers:import only — never in the Expo app

# scripts/notify-app-update.mjs defaults (optional)
# APP_VERSION=1.0.0
# APP_BUILD_NUMBER=4
